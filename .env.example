# Resend transactional email.
# Free plan is enough for MVP waitlist/auth emails.
RESEND_API_KEY=
RESEND_FROM="PRSLOY <hello@prsloy.com>"

# Optional: receive waitlist/access-request notifications by email.
WAITLIST_NOTIFY_EMAIL=

# Optional: receive waitlist/access-request notifications in Telegram.
TELEGRAM_BOT_TOKEN=
TELEGRAM_NOTIFY_CHAT_ID=

# Optional canonical / OG URL override.
NEXT_PUBLIC_SITE_URL=https://prsloy.com
