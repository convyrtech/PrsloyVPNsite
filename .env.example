# Resend transactional email.
# Free plan is enough for MVP waitlist/auth emails.
RESEND_API_KEY=
RESEND_FROM="PRSLOY <hello@prsloy.online>"

# Required for email/password accounts.
# Vercel KV uses KV_REST_API_URL + KV_REST_API_TOKEN.
# Vercel Marketplace Upstash may prefix them as UPSTASH_REDIS_REST_KV_REST_API_*.
# Plain Upstash Redis REST uses UPSTASH_REDIS_REST_URL + UPSTASH_REDIS_REST_TOKEN.
AUTH_SECRET=
KV_REST_API_URL=
KV_REST_API_TOKEN=
UPSTASH_REDIS_REST_KV_REST_API_URL=
UPSTASH_REDIS_REST_KV_REST_API_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: receive waitlist/access-request notifications by email.
WAITLIST_NOTIFY_EMAIL=

# Optional: receive waitlist/access-request notifications in Telegram.
TELEGRAM_BOT_TOKEN=
TELEGRAM_NOTIFY_CHAT_ID=

# Optional canonical / OG URL override.
NEXT_PUBLIC_SITE_URL=https://www.prsloy.online
